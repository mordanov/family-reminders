# Copy this to .env and fill in values

# ─── Security ────────────────────────────────────────
SECRET_KEY=super-secret-change-in-production-use-a-long-random-string

# ─── Database ────────────────────────────────────────
# Managed by docker-compose; only change if using external DB
DATABASE_URL=postgresql+asyncpg://reminders:reminders@db:5432/reminders

# ─── Email / SMTP (optional) ─────────────────────────
# Leave blank to disable email reminders (they'll be logged to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=reminders@app.local

# ─── Reminder check interval (seconds) ──────────────
REMINDER_CHECK_INTERVAL=60
